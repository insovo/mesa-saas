# ── lark-ingest 本地原型配置 ──────────────────────────────
# 复制为 .env 后填写。.env 已被 .gitignore 排除,切勿提交。

# MESA 实例地址(末尾不带 /)。本地原型一般直接指向生产,候选人入"待解析"池可随时删。
MESA_BASE_URL=https://insovo.top

# MESA 公开上传链接 token(在 MESA 里建一个长期 UploadShareLink 后复制 token 串)
# 注意:token 是公开上传凭证,别外发、别提交 git。
UPLOAD_TOKEN=__PASTE_UPLOAD_LINK_TOKEN__

# 可选:lark-cli 可执行文件路径(默认走 PATH 里的 lark-cli)
# LARK_CLI=/opt/homebrew/bin/lark-cli

# 可选:允许入库的文件后缀(逗号分隔,默认 pdf,doc,docx)
# ALLOWED_EXT=pdf,doc,docx

# 可选:文件大小上限(字节,默认 20MB,对齐 MESA MAX_SIZE)
# MAX_SIZE=20971520

# 可选:群内回执开关(默认 true)。机器人回复上传成功/失败。
# 需飞书应用已开「发送消息」权限(im:message);未开时设 false 关掉,不影响入库。
# REPLY_ENABLED=true
