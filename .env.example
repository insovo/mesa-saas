# MESA Recruit · 生产环境变量样例
# 复制为 .env(根目录)后填入真实值。.env 严禁入 Git(已在 .gitignore)。
# 凭证占位用 __SET_BY_OPS__,运维同事据此填生产值。

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=mesa
POSTGRES_USER=mesa
# 至少 24 字节随机串: openssl rand -base64 24
POSTGRES_PASSWORD=__SET_BY_OPS__

# ─── JWT ───────────────────────────────────────────────────────
# 至少 32 字节随机串: openssl rand -hex 32
JWT_SECRET=__SET_BY_OPS__

# ─── 站点 ──────────────────────────────────────────────────────
# CORS 白名单(后端用),逗号分隔多个 origin。生产请写真实域名,不要图省事写 *。
WEB_ORIGIN=https://recruit.example.com

# ─── 暴露端口 ──────────────────────────────────────────────────
# 默认 80;若已有 Cloudflare Tunnel 或外层 Nginx,可改成 8080 等内网端口
WEB_HTTP_PORT=80

# ─── 日志 ──────────────────────────────────────────────────────
LOG_LEVEL=info

# ─── (阶段② R2)─────────────────────────────────────────────────
# 仅当后端接入 Cloudflare R2 后启用,占位先放着
R2_ACCOUNT_ID=__SET_BY_OPS__
R2_ACCESS_KEY_ID=__SET_BY_OPS__
R2_SECRET_ACCESS_KEY=__SET_BY_OPS__
R2_BUCKET=mesa-resumes
R2_PUBLIC_BASE_URL=https://r2.example.com

# ─── (阶段⑤ 备份)──────────────────────────────────────────────
# 备份桶独立于业务桶,只允许 backup 凭证写入
R2_BACKUP_BUCKET=mesa-backups

# ─── LLM 简历解析 (Kimi / Moonshot AI) ─────────────────────────
# 系统统一持有的 API Key,所有用户共享。https://platform.moonshot.cn
KIMI_API_KEY=__SET_BY_OPS__
KIMI_MODEL=moonshot-v1-32k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# ─── 飞书简历自动入库 (lark-ingest 容器) ───────────────────────
# 飞书自建应用凭证;缺省时 lark-ingest 容器会重启循环,不影响其它服务。
LARK_APP_ID=__SET_BY_OPS__
LARK_APP_SECRET=__SET_BY_OPS__
LARK_BRAND=feishu
# MESA 长期公开上传链接 token(决定自动入库候选人的归属人 ownerId)
LARK_UPLOAD_TOKEN=__SET_BY_OPS__
# 入库目标地址,默认走内网 backend 直连(无需改);如需走外网填 https://insovo.top
# LARK_MESA_BASE_URL=http://backend:3001
