// Prisma schema — Stage ① 全栈闭环
// 字段映射 ui_kits/mesa-recruit/data.js 的 window.MESA_* 形状。
// 新增字段请同步在 data.js 与前端消费方做对应处理。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  VIEWER
}

enum Urgency {
  high
  mid
  low
}

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String?
  role              Role      @default(RECRUITER)
  avatar            String? // 头像 URL,登录用户评价时自动带出
  jobTitle          String?   @map("job_title") // 内部角色显示(如 HR · 负责人 / 技术面试官 / HRBP)
  isActive          Boolean   @default(true) @map("is_active") // 停用 → 不能登录、所分享的 ShareLink 失效(返回 410)
  deactivatedReason String?   @map("deactivated_reason") // 停用原因(可选,登录被拒时返回)
  deactivatedAt     DateTime? @map("deactivated_at")
  // === 第三阶段+:tokenVersion 强制下线 + TOTP 2FA ===
  tokenVersion      Int       @default(0) @map("token_version") // JWT payload 带此值,改密/重置/强制下线时 ++
  totpEnabled       Boolean   @default(false) @map("totp_enabled")
  totpSecret        String?   @map("totp_secret") // base32,启用后才有
  totpEnabledAt     DateTime? @map("totp_enabled_at")
  totpRecoveryCodes String[]  @default([]) @map("totp_recovery_codes") // 备份码 bcrypt 哈希数组(10 个,用一个移除一个)
  // 绩效导出 HR 电子章（R2 key，PNG）
  hrSignatureKey       String?   @map("hr_signature_key")
  hrSignatureUpdatedAt DateTime? @map("hr_signature_updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  candidates Candidate[] @relation("CandidateOwner")
  reviews    Review[]

  accessPolicy      UserAccessPolicy?
  departmentScopes  UserDepartmentScope[]
  jobScopes         UserJobScope[]
  createdShareLinks ShareLink[]           @relation("ShareLinkCreator")
  passwordHistory   PasswordHistory[]

  @@index([email])
  @@map("users")
}

// 邮箱验证码 — 自助修改邮箱/密码 + 忘记密码 都走此表
// codeHash 用 bcrypt 存,避免日志/DB 备份泄露明文
// purpose: CHANGE_EMAIL(校验当前邮箱) / CHANGE_EMAIL_NEW(校验目标新邮箱) / CHANGE_PASSWORD / RESET_PASSWORD
model EmailVerificationCode {
  id           String    @id @default(uuid()) @db.Uuid
  email        String // 收件邮箱(可与 user.email 不同 — 比如改邮箱场景下的"新邮箱")
  userId       String?   @map("user_id") @db.Uuid // 登录态发起的验证码会带 userId;忘记密码场景为 null
  purpose      String // CHANGE_EMAIL | CHANGE_EMAIL_NEW | CHANGE_PASSWORD | RESET_PASSWORD
  codeHash     String    @map("code_hash")
  expiresAt    DateTime  @map("expires_at")
  consumedAt   DateTime? @map("consumed_at")
  attemptCount Int       @default(0) @map("attempt_count")
  ip           String?
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([email, purpose])
  @@index([userId])
  @@map("email_verification_codes")
}

// 用户访问策略 — 仅普通用户(非 ADMIN)生效。ADMIN 拥有全部页面/模块权限。
// pageKeys / moduleKeys 是字符串数组,具体可选值见 server/src/lib/permissionKeys.js
model UserAccessPolicy {
  userId             String   @id @map("user_id") @db.Uuid
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pageKeys           String[] @default([]) @map("page_keys")
  moduleKeys         String[] @default([]) @map("module_keys")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("user_access_policies")
}

// 用户部门数据范围授权 — includeChildren 默认 true(部门授权默认包含子部门)
model UserDepartmentScope {
  id              String     @id @default(uuid()) @db.Uuid
  userId          String     @map("user_id") @db.Uuid
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId    String     @map("department_id") @db.Uuid
  department      Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  includeChildren Boolean    @default(true) @map("include_children")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
  @@map("user_department_scopes")
}

// 用户 JD 数据范围授权
model UserJobScope {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String   @map("job_id") @db.Uuid
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@map("user_job_scopes")
}

model Candidate {
  id         String  @id @default(uuid()) @db.Uuid
  externalId String? @unique @map("external_id")

  name   String
  gender String?
  animal String?
  avatar String?

  education String?
  school    String?
  major     String?
  age       Int?
  location  String?
  yearsExp  Int?    @map("years_exp")
  phone     String?
  email     String?

  appliedFor String?   @map("applied_for")
  jdMatch    Int?      @map("jd_match")
  status     String?
  source     String?
  pushedAt   DateTime? @map("pushed_at")

  parser           String?
  parserConfidence Int?    @map("parser_confidence")

  // 非空且距今 <10min 即视为「正在解析」— withDerivedCandidate 据此派生 parsing 布尔,
  // 让所有读 candidate 的页面(列表/详情/概览)统一显示「解析中」。解析完成/失败置 null。
  parsingStartedAt DateTime? @map("parsing_started_at")

  tags             String[] @default([])
  // 简历事实展示字段:由 parseResume (阶段一纯抽取) 产出 markdown bullet 字符串,
  // JD match 只更新匹配度/风险/亮点/洞察,不再改写这些字段。
  skills           String?  @db.Text // markdown bullet 字符串("- xxx\n- yyy")
  risks            String[] @default([])
  highlights       String[] @default([])
  experience       String?  @db.Text // markdown bullet 字符串
  educationHistory String?  @map("education_history") @db.Text // markdown bullet 字符串
  attachment       String?
  aiSummary        String?  @map("ai_summary") @db.Text // LLM 输出的纯文本简报(HR 可读)

  // === V2 新字段(2026-05-24 新增,与 candidate-detail-flat 设计稿对齐) ===
  // 部分由 LLM 在 parseResume + matchAgainstJob 阶段输出(见 lib/kimi.js),部分由 admin 手动维护
  aiSuggestedTags   String[] @default([]) @map("ai_suggested_tags") // LLM 建议标签,左侧 TagsModule 「+ 添加」可选
  insights          Json     @default("[]") // [{kind:"up"|"down", text:""}] LLM 输出洞察
  matchedFor        String[] @default([]) @map("matched_for") // 相对当前 JD 的匹配维度 ["教育背景","技能栈","工作经验"]
  againstFor        String[] @default([]) @map("against_for") // 不匹配维度
  profileCompletion Int      @default(0) @map("profile_completion") // 资料完整度 0-100,后端按字段填充率算
  languages         Json     @default("[]") // [{name:"中文",level:"母语"}, {name:"英语",level:"CEFR C1"}]
  documents         Json     @default("{\"resume\":[],\"materials\":[],\"portfolio\":[]}") // 附件分类: resume/materials/portfolio,每项 [{id,kind:"file"|"link"|"note",name/label,url?,size?,verified?,content?}]

  ownerId String? @map("owner_id") @db.Uuid
  owner   User?   @relation("CandidateOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 关联的 JD(可选) — 设置后 jdMatch/risks/highlights 才有意义
  jobId String? @map("job_id") @db.Uuid
  job   Job?    @relation("CandidateJob", fields: [jobId], references: [id], onDelete: SetNull)

  // 关联部门(可选) — 独立于 JD,允许"先归到某部门,后续再定具体 JD"的工作流
  departmentId String?     @map("department_id") @db.Uuid
  department   Department? @relation("CandidateDepartment", fields: [departmentId], references: [id], onDelete: SetNull)

  interviews             Interview[]
  employee               Employee?
  notes                  CandidateNote[]
  shareLinks             ShareLink[]
  reviews                Review[]
  interviewEvaluations   InterviewEvaluation[]
  performanceEvaluations PerformanceEvaluation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([appliedFor])
  @@index([status])
  @@index([ownerId])
  @@index([jobId])
  @@map("candidates")
}

model Job {
  id          String  @id @default(uuid()) @db.Uuid
  externalId  String? @unique @map("external_id")
  title       String
  dept        String?
  owner       String?
  openings    Int     @default(1)
  candidates  Int     @default(0)
  level       String?
  location    String?
  urgency     Urgency @default(mid)
  status      String? @default("招聘中")
  description String? @db.Text // JD 详情(职责/要求/福利) — LLM 用作 JD 匹配度评估的素材

  // === V2 新字段(JD 详情弹窗 + 岗位概览 Card 用)===
  employment           String? // "全职" / "兼职" / "实习" / "合同制"
  salary               String? // "30K-40K · 16薪"
  levelRange           String?   @map("level_range") // "P6-P7" (跟 level 字段不同语义,level=单一职级)
  yearsExpRange        String?   @map("years_exp_range") // "5-7 年" (字符串,跟 Candidate.yearsExp Int 不同)
  educationRequirement String?   @map("education_requirement") // "本科及以上"
  languageRequirement  String?   @map("language_requirement") // "英语 CEFR B2+"
  publishedAt          DateTime? @map("published_at")
  deadline             DateTime?
  responsibilities     String[]  @default([])
  requirements         String[]  @default([])
  nice                 String[]  @default([])
  benefits             String[]  @default([])

  interviews           Interview[]
  employees            Employee[]
  linkedCandidates     Candidate[]           @relation("CandidateJob")
  uploadLinks          UploadShareLink[]     @relation("UploadLinkJob")
  userScopes           UserJobScope[]
  interviewEvaluations InterviewEvaluation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dept])
  @@index([urgency])
  @@map("jobs")
}

model Department {
  id         String                @id @default(uuid()) @db.Uuid
  externalId String?               @unique @map("external_id")
  name       String
  code       String?
  parentId   String?               @map("parent_id") @db.Uuid
  parent     Department?           @relation("DeptParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   Department[]          @relation("DeptParent")
  candidates Candidate[]           @relation("CandidateDepartment")
  userScopes UserDepartmentScope[]
  head       String?
  headcount  Int                   @default(0)
  openHc     Int                   @default(0) @map("open_hc")
  sortOrder  Int                   @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([parentId, sortOrder])
  @@map("departments")
}

model Employee {
  id         String  @id @default(uuid()) @db.Uuid
  externalId String? @unique @map("external_id")

  candidateId String?    @unique @map("candidate_id") @db.Uuid
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  name      String
  gender    String?
  animal    String?
  avatar    String?
  education String?
  school    String?
  major     String?
  age       Int?
  location  String?
  yearsExp  Int?    @map("years_exp")
  phone     String?
  email     String?

  appliedFor   String? @map("applied_for")
  jobId        String? @map("job_id") @db.Uuid
  job          Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  dept         String?
  jdOwner      String? @map("jd_owner")
  level        String?
  workLocation String? @map("work_location")
  jdMatch      Int?    @map("jd_match")

  stage            String?
  plannedHireDate  DateTime? @map("planned_hire_date")
  actualHireDate   DateTime? @map("actual_hire_date")
  probationEndDate DateTime? @map("probation_end_date")
  regularizeDate   DateTime? @map("regularize_date")
  regularizeAdvice String?   @map("regularize_advice")
  // 二期-4 流失原因 (Offer 已发但未入职 / 入职后离职):枚举存字符串
  // "另选 Offer" / "薪资不达预期" / "个人原因" / "岗位变更" / "其它"
  dropReason       String?   @map("drop_reason")
  dropReasonDetail String?   @map("drop_reason_detail") @db.Text
  hrbp             String?
  directManager    String?   @map("direct_manager")

  checklist Json @default("{}")
  probation Json @default("{}")
  events    Json @default("[]")
  riskItems Json @default("[]") @map("risk_items")

  parser           String?
  parserConfidence Int?     @map("parser_confidence")
  source           String?
  attachment       String?
  tags             String[] @default([])

  performanceEvaluations PerformanceEvaluation[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([dept])
  @@index([stage])
  @@index([jobId])
  @@map("employees")
}

// 候选人评价 — 不同于 CandidateNote (内部备注)
// Review 可以由登录用户 + 公开访客(经 ShareLink token)都提交
// 公开提交的 authorName 强制必填,内部提交自动从登录 User 拿
model Review {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @map("candidate_id") @db.Uuid
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  // 作者信息(快照,即便 User 删了也能展示)
  authorName   String  @map("author_name")
  authorRole   String? @map("author_role") // 如 "HR · 负责人" / "技术面试官"
  authorAvatar String? @map("author_avatar")

  // 关联用户(仅登录用户),公开评论为 null
  userId String? @map("user_id") @db.Uuid
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  via        String  @default("internal") // 提交渠道: "internal" | "public"
  shareToken String? @map("share_token") // 公开提交时记录是经哪个 share token

  // 可见范围: "public"(全员) | "internal"(仅登录账号) | "admin"(仅 ADMIN)
  visibility String @default("public")

  content     String @db.Text // ≤500 字符
  // attachments: [{ type: "image"|"file"|"link", name, url, size?, contentType? }]
  attachments Json   @default("[]")

  // 回复 — 1 级嵌套(主父亲, 兼容旧数据)
  parentId String?  @map("parent_id") @db.Uuid
  parent   Review?  @relation("ReviewParent", fields: [parentId], references: [id], onDelete: SetNull)
  replies  Review[] @relation("ReviewParent")

  // 批量回复时记录额外引用的多条评价 id (JSON 数组), 至少 1 个 = parentId
  // 单次回复时此字段可为 [] 或 [parentId]
  referencedIds Json @default("[]") @map("referenced_ids")

  // 删除流: 普通作者只能"请求删除",admin 批准后才真删除(deletedAt 标记 soft-delete)
  deletedAt         DateTime? @map("deleted_at")
  deleteRequested   DateTime? @map("delete_requested")
  deleteRequestedBy String?   @map("delete_requested_by") // authorName 或 userId

  // admin 隐藏 — 普通用户看不到,admin 视角显示"已隐藏"标记
  hidden Boolean @default(false)

  // 表决态度(用于回复评价): "approve" | "reject" | null(不表态)
  stance String?

  // 表决票数(用于显示与排序)
  upvotes   Int @default(0)
  downvotes Int @default(0)

  votes ReviewVote[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([candidateId])
  @@index([userId])
  @@index([parentId])
  @@map("reviews")
}

// 登录用户对评价的投票, 用于去重(一个用户对一个评价只能 +1 或 -1 或不投)
// 公开访客投票不写此表(无法可靠去重), 直接累加 Review.up/downvotes,前端用 localStorage 限制
model ReviewVote {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String   @map("user_id") @db.Uuid
  value     Int // +1 | -1
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([reviewId, userId])
  @@map("review_votes")
}

// 候选人备注 — 详情页时间线显示
model CandidateNote {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String    @map("candidate_id") @db.Uuid
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  authorId    String?   @map("author_id") @db.Uuid
  authorName  String?   @map("author_name")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([candidateId])
  @@map("candidate_notes")
}

// 分享给招聘官的公开链接
// token 是不可猜的 UUID,公开页只能通过 token 访问对应候选人
// expiresAt = null 表示无限期,否则到期后接口返回 410
model ShareLink {
  id              String    @id @default(uuid()) @db.Uuid
  token           String    @unique // 用于公开 URL
  candidateId     String    @map("candidate_id") @db.Uuid
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  expiresAt       DateTime? @map("expires_at") // null = 无限期
  maxViews        Int?      @map("max_views") // null = 不限制访问次数,否则达 maxViews 后接口拒绝
  createdBy       String?   @map("created_by") @db.Uuid
  creator         User?     @relation("ShareLinkCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  viewCount       Int       @default(0) @map("view_count")
  lastViewedAt    DateTime? @map("last_viewed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  // 公开端可见性开关 — 不修改候选人本身,只控制本 ShareLink 的展示策略
  showContact     Boolean   @default(true) @map("show_contact") // 联系方式(phone/email)是否露出(mask)
  showAttachments Boolean   @default(false) @map("show_attachments") // 评价表单的「附件上传」input 是否开放
  showInterviewEval Boolean @default(true) @map("show_interview_eval") // 公开页是否显示「填写面试评价」入口(默认开)
  showInterviewEvalList Boolean @default(false) @map("show_interview_eval_list") // 公开页是否展示已有(已提交)面试评价记录(默认关)
  showResume      Boolean   @default(true) @map("show_resume") // 公开页是否允许查看原始简历文件(默认开)
  showNotes       Boolean   @default(false) @map("show_notes") // 公开页是否展示内部备注(默认关;洞察不受此控,始终展示)
  // 创建时快照:允许公开展示的 module key 数组 ["candidate.contact","candidate.reviews",...]
  // 公开访问最终模块 = allowedModules ∩ 创建者当前权限,创建者被停用则整链接 410
  allowedModules  String[]  @default([]) @map("allowed_modules")

  @@index([candidateId])
  @@index([token])
  @@index([createdBy])
  @@map("share_links")
}

// 公开「上传分享链接」 — 反向用法:登录用户生成 token → 外部(候选人本人 / 同事 / 猎头)通过
// 公开 URL https://insovo.top/upload/<token> 上传简历给系统。与 ShareLink(分享候选人简报给外部看)
// 是镜像关系,所以单独建表避免字段语义混用(viewCount 既算看也算收会很乱)。
//
// 安全要点:
//   - token = 32 字符 URL-safe base64,不可猜
//   - 公开 endpoint 受 maxUploads + expiresAt 双重限速,达到任一上限就拒绝
//   - 上传的 candidate.ownerId 自动 = createdBy(归属链接创建者),source 默认 = defaultSource 或链接 note
//   - defaultJobId 让外部"自动关联到这个 JD"(招聘官分享时常用),外部上传者也可改选其它 JD
model UploadShareLink {
  id            String    @id @default(uuid()) @db.Uuid
  token         String    @unique // 公开 URL 的 path 参数,不可猜
  defaultJobId  String?   @map("default_job_id") @db.Uuid
  defaultJob    Job?      @relation("UploadLinkJob", fields: [defaultJobId], references: [id], onDelete: SetNull)
  defaultSource String?   @map("default_source") // 预填来源,如"罗卡推荐",外部上传时默认带上(可被外部覆盖)
  note          String?   @db.Text // 给外部上传者的提示文案,如"请上传 PDF 简历,我们会在 24h 内联系您"
  expiresAt     DateTime? @map("expires_at") // null = 无限期
  maxUploads    Int?      @map("max_uploads") // null = 不限制,否则达 maxUploads 后接口拒绝(对应截图"最多 200 份")
  uploadCount   Int       @default(0) @map("upload_count")
  createdBy     String?   @map("created_by") @db.Uuid
  lastUploadAt  DateTime? @map("last_upload_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([token])
  @@index([createdBy])
  @@map("upload_share_links")
}

// 系统级 KV 设置 — 仅 admin 可读写
// 用于覆盖 .env 默认值,例如 kimi.api_key / kimi.model
// value 字段: 当 encrypted=true 时存 base64(iv:authTag:ciphertext) — AES-256-GCM
model SystemSetting {
  key       String   @id // "kimi.api_key", "kimi.model", ...
  value     String // 加密或明文,看 encrypted 字段
  encrypted Boolean  @default(false)
  updatedBy String?  @map("updated_by") @db.Uuid
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_settings")
}

model Interview {
  id         String  @id @default(uuid()) @db.Uuid
  externalId String? @unique @map("external_id")

  candidateId   String?    @map("candidate_id") @db.Uuid
  candidate     Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  candidateName String?    @map("candidate_name")

  jobId    String? @map("job_id") @db.Uuid
  job      Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  jobTitle String? @map("job_title")

  round          String?
  category       String? // V2 新增: "技术" / "HR" / "业务" / 自定义
  mode           String?
  status         String?
  recommendation String?
  scheduledAt    DateTime? @map("scheduled_at")
  interviewer    String? // 老字段,保留向后兼容(单 string,展示用)
  managers       Json      @default("[]") // V2 新增: HR/招聘官列表 [{name,role,animal,avatar}]
  interviewers   Json      @default("[]") // V2 新增: 面试官列表(多人)[{name,role,animal,avatar}]
  link           String? // V2 新增: 会议链接 / 线下地址
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  interviewEvaluations InterviewEvaluation[]

  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@map("interviews")
}

// 审计日志 — 记录关键操作便于追溯
// 写入入口在 server/src/lib/audit.js writeLog
// action 命名约定: <entity>.<verb>  如 user.create / user.deactivate / user.policy.update / share.create / candidate.delete / auth.login / auth.login_failed
model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid // 触发动作的登录用户 id;系统/匿名场景为 null
  actorEmail String?  @map("actor_email") // 快照,即便 User 删了仍能看
  action     String // 见上方约定
  entityType String?  @map("entity_type") // user / candidate / job / department / share_link / ...
  entityId   String?  @map("entity_id") // 可能不是 uuid(比如 share token),用 string
  diff       Json     @default("{}") // { before?, after?, message? }
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// 密码历史 — 防止重复使用最近 N 次密码
// 每次改密成功就写一条,后台保留最近 5 条(超出由 lib/passwordHistory.js prune)
model PasswordHistory {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("password_history")
}

// 面试评价 — 招聘官生成 token,面试官(无登录)通过公开链接填写
// 提交后可导出与原 Excel 模板版式一致的 .xlsx 文件
// 详见 /Users/mysaria/Project/mesa/面试评价模块设计规划.md
model InterviewEvaluation {
  id String @id @default(uuid()) @db.Uuid

  candidateId String     @map("candidate_id") @db.Uuid
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewId String?    @map("interview_id") @db.Uuid
  interview   Interview? @relation(fields: [interviewId], references: [id], onDelete: SetNull)
  jobId       String?    @map("job_id") @db.Uuid
  job         Job?       @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // 公开 token (32 字符 URL-safe random, 沿用 ShareLink 设计)
  token     String    @unique
  // 状态机: link_sent(初建) → draft(面试官保存过) → submitted(已提交) → revoked
  status    String    @default("link_sent")
  expiresAt DateTime? @map("expires_at")

  // 候选人信息快照(创建邀请时预填,面试官可改;后续 candidate 改名不回填)
  candidateName         String    @map("candidate_name")
  position              String?
  region                String?
  interviewDate         DateTime? @map("interview_date")
  interviewer           String // 面试官姓名,识别评价来源(必填)
  languageStrength      String?   @map("language_strength")
  currentCity           String?   @map("current_city")
  department            String?
  timezoneCollaboration String?   @map("timezone_collaboration")

  // 评分数组快照: [{ key, score, remark }] - key 对应 lib/interviewEvalTemplate.js SCORE_DIMENSIONS
  // 权重不存,从 templateVersion 反查代码常量
  scores Json @default("[]")

  // 纪要(对应 Excel B20/B22/B24/B26 合并块)
  strengths         String? @db.Text
  risks             String? @db.Text
  followUpQuestions String? @map("follow_up_questions") @db.Text
  finalOpinion      String? @map("final_opinion") @db.Text

  // 汇总(提交时算并存,导出兜底 + 列表展示用,无需打开 xlsx)
  totalScore     Float?  @map("total_score")
  recommendation String?

  // 模板版本管理 — 升级模板时旧记录仍能溯源
  templateVersion  String  @default("v1") @map("template_version")
  templateFileHash String? @map("template_file_hash")

  // 元信息
  createdBy     String?   @map("created_by") @db.Uuid
  submittedAt   DateTime? @map("submitted_at")
  exportedAt    DateTime? @map("exported_at")
  exportedCount Int       @default(0) @map("exported_count")
  lastViewedAt  DateTime? @map("last_viewed_at")
  viewCount     Int       @default(0) @map("view_count")
  revokedAt     DateTime? @map("revoked_at")
  revokedBy     String?   @map("revoked_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([candidateId])
  @@index([interviewId])
  @@index([token])
  @@index([createdBy])
  @@index([status])
  @@map("interview_evaluations")
}

// 属地员工绩效评价 — 锚定 Employee；自评 / 主管双 token 公开填写；导出四语种 Excel
model PerformanceEvaluation {
  id String @id @default(uuid()) @db.Uuid

  employeeId  String    @map("employee_id") @db.Uuid
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  candidateId String?   @map("candidate_id") @db.Uuid
  candidate   Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  selfToken    String @unique @map("self_token")
  managerToken String @unique @map("manager_token")

  // draft → self_done → submitted → revoked
  status    String    @default("draft")
  expiresAt DateTime? @map("expires_at")

  employeeName  String  @map("employee_name")
  employeeNo    String? @map("employee_no")
  position      String?
  department    String?
  level         String?
  lineManager   String? @map("line_manager")
  reviewPeriod  String  @map("review_period")
  evalDate      DateTime? @map("eval_date")

  // [{ key, weight, selfScore, managerScore, evidence }]
  scores Json @default("[]")

  achievements    String? @db.Text
  developmentPlan String? @map("development_plan") @db.Text
  nextGoals       String? @map("next_goals") @db.Text

  selfTotal     Float?   @map("self_total")
  managerTotal  Float?   @map("manager_total")
  rating        String?
  pipTriggered  Boolean? @map("pip_triggered")

  selfSubmittedAt    DateTime? @map("self_submitted_at")
  managerSubmittedAt DateTime? @map("manager_submitted_at")

  // 确认与签字 — R2 PNG key；提交前必填对应角色
  selfSignatureKey       String?   @map("self_signature_key")
  selfSignedAt           DateTime? @map("self_signed_at")
  managerSignatureKey    String?   @map("manager_signature_key")
  managerSignedAt        DateTime? @map("manager_signed_at")

  templateVersion  String  @default("v1") @map("template_version")
  templateFileHash String? @map("template_file_hash")

  createdBy     String?   @map("created_by") @db.Uuid
  submittedAt   DateTime? @map("submitted_at")
  exportedAt    DateTime? @map("exported_at")
  exportedCount Int       @default(0) @map("exported_count")
  lastViewedAt  DateTime? @map("last_viewed_at")
  viewCount     Int       @default(0) @map("view_count")

  // 各角色可修改次数：null=不限；达上限后公开页草稿只读（仍允许提交）
  selfMaxEdits     Int? @map("self_max_edits")
  managerMaxEdits  Int? @map("manager_max_edits")
  selfEditCount    Int  @default(0) @map("self_edit_count")
  managerEditCount Int  @default(0) @map("manager_edit_count")

  revokedAt     DateTime? @map("revoked_at")
  revokedBy     String?   @map("revoked_by") @db.Uuid
  deletedAt     DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([employeeId])
  @@index([candidateId])
  @@index([selfToken])
  @@index([managerToken])
  @@index([createdBy])
  @@index([status])
  @@map("performance_evaluations")
}
