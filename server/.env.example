# 复制为 .env 后填入真实值。.env 严禁入 Git。
# 阶段① 本地开发,值与 docker-compose.dev.yml 对齐;生产环境凭证由阶段⑤ secrets 注入。

# PostgreSQL 连接串
DATABASE_URL="postgresql://mesa:mesa_dev_only@127.0.0.1:5432/mesa?schema=public"

# Redis 连接串
REDIS_URL="redis://127.0.0.1:6379"

# JWT 签名密钥 — 至少 32 字节随机串。本地开发可用 `openssl rand -hex 32` 生成。
# 严禁使用此示例值,严禁 commit 真实值。
JWT_SECRET="__REPLACE_WITH_OPENSSL_RAND_HEX_32__"

# 服务监听
HOST="127.0.0.1"
PORT="3001"

# 前端 dev server 来源(Vite 默认 5173) — CORS 白名单
WEB_ORIGIN="http://localhost:5173"

# 日志级别 (trace|debug|info|warn|error|fatal)。生产建议设为 warn 降噪 + 减少敏感信息落盘。
LOG_LEVEL="info"

# ─── 以下为可选服务,本地开发可留空;生产值由运维注入(严禁 commit 真实值)───

# Cloudflare R2 对象存储(简历/附件)。留空则文件上传相关功能不可用。
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_BASE_URL=""

# Kimi(Moonshot)LLM 简历解析。KIMI_API_KEY 留空则解析功能降级。
KIMI_API_KEY=""
KIMI_MODEL="moonshot-v1-32k"
KIMI_BASE_URL="https://api.moonshot.cn/v1"

# Resend 邮件(验证码/找回密码)。APP_BASE_URL 用于邮件内链接。
RESEND_API_KEY=""
RESEND_FROM="MESA Recruit <onboarding@resend.dev>"
APP_BASE_URL="http://localhost:5173"

# 飞书卡片回调校验(routes/feishu.js)。未配置 FEISHU_VERIFICATION_TOKEN 时回调端点禁用。
FEISHU_VERIFICATION_TOKEN=""
FEISHU_ENCRYPT_KEY=""

# 飞书 Bot(lib/feishuNotify.js 换 tenant_access_token)。
LARK_APP_ID=""
LARK_APP_SECRET=""
LARK_BRAND="feishu"
