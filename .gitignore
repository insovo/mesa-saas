# 通用
.DS_Store
*.log
.vscode/
.idea/

# Node / 构建产物(阶段① 引入 — 仅作用于 server/ 和 web/)
node_modules/
dist/
.cache/

# 环境变量 — 严禁入库
.env
.env.local
.env.*.local
!.env.example

# Prisma 本地
server/prisma/*.db

# 容器卷数据(本机持久化,不入库)
.docker-data/

# TLS 证书 / 私钥 — 永远不入库,仅 VPS 本地持有
web/certs/
*.pem
*.key

# Playwright 临时输出
.playwright-mcp/
*.png
# 例外:前端产品静态素材(登录页人像等)必须入库,否则 CI/生产构建缺图失败
!web/src/assets/**

# Git worktrees(本机隔离工作区,不入库)
.worktrees/

# Claude Code 私域(会话状态 / 工具默认 worktree 等,不入库)
.claude/

# 交付文档源 md(只保留 docx)— 可选,保留 md 也行
# delivery-docs/src/
